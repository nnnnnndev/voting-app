# Copy to .env and fill in. Do not commit .env.
#
# These come from the Entra app registration (see infra/app_registration.md).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Redirect URI registered in Entra. For local dev:
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# SharePoint site to store ballots in (hostname + site path).
# e.g. umass.sharepoint.com and /sites/MIE-Faculty
SHAREPOINT_HOSTNAME=
SHAREPOINT_SITE_PATH=

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
